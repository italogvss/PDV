# =============================================================
# PDV-Ultra - Template de variaveis de DESENVOLVIMENTO
# Copie para .env e preencha os valores. NUNCA commite o .env.
# Toda a stack roda no Docker: docker compose up
# =============================================================

# -- Banco de dados (MySQL) -----------------------------------
DB_ROOT_PASSWORD=troque_me
DB_NAME=pdv-ultra

# -- Backend (.NET) -------------------------------------------
# Server=db -> nome do servico MySQL no docker-compose.
# Mantenha Database e Password iguais a DB_NAME / DB_ROOT_PASSWORD.
DB_CONNECTION_STRING=Server=db;Port=3306;Database=pdv-ultra;User=root;Password=troque_me;AllowPublicKeyRetrieval=True;SslMode=None;
# JWT - minimo 32 caracteres aleatorios.
JWT_SECRET=troque_por_uma_string_aleatoria_de_no_minimo_32_chars
# Validade do access token em horas (opcional, default 8).
JWT_EXPIRES_HOURS=8
# Origem do frontend liberada no CORS - sem barra no final.
FRONTEND_URL=http://localhost:5173

# -- Google Sign-In -------------------------------------------
# __ vira chave aninhada (Authentication:Google:...) no ASP.NET Core.
# O backend so valida o ID token - nao precisa mais de ClientSecret.
Authentication__Google__ClientId=seu_google_client_id

# -- Frontend (Vite) ------------------------------------------
# Caminho relativo - o Vite faz proxy de /api para a API em dev.
VITE_API_URL=/api
# Client ID do Google usado pelo GIS no navegador (mesmo valor do backend).
VITE_GOOGLE_CLIENT_ID=seu_google_client_id
# Desativa o guard de autenticacao em dev (nunca true em producao).
VITE_BYPASS_AUTH=false
