# =============================================================
# PDV-Lorena — Environment Variables Template
# Copy this file to .env and fill in your local values.
# NEVER commit .env to version control.
# =============================================================

# --------------------------
# Database
# --------------------------
DB_ROOT_PASSWORD=change_me
DB_NAME=pdv
DB_USER=pdvuser
DB_PASSWORD=change_me
DB_CONNECTION_STRING=Server=db;Port=3306;Database=pdv;User=pdvuser;Password=change_me

# --------------------------
# JWT
# --------------------------
# Must be at least 32 random characters
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
JWT_EXPIRES_HOURS=8

# --------------------------
# CORS
# --------------------------
# Exact origin of the frontend — no trailing slash
FRONTEND_URL=http://localhost:3000

# --------------------------
# ASP.NET Core
# --------------------------
ASPNETCORE_ENVIRONMENT=Development

# --------------------------
# Frontend (Vite)
# --------------------------
# URL the browser uses to reach the API
VITE_API_URL=http://localhost:5000
