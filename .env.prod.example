# =============================================================
# PDV-Ultra - Template de variaveis de PRODUCAO
# Copie para .env.prod e preencha os valores reais.
# NUNCA commite o .env.prod no repositorio.
# Subir: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# =============================================================

# -- Banco de dados (MySQL) -----------------------------------
DB_ROOT_PASSWORD=troque_me
DB_NAME=pdv

# -- Backend (.NET) -------------------------------------------
DB_CONNECTION_STRING=Server=db;Port=3306;Database=pdv;User=root;Password=troque_me;AllowPublicKeyRetrieval=True;SslMode=None;
# JWT - minimo 32 caracteres aleatorios.
JWT_SECRET=troque_por_uma_string_aleatoria_de_no_minimo_32_chars
# Validade do access token em horas (opcional, default 8).
JWT_EXPIRES_HOURS=8
# Dominio/IP publico da VPS - sem barra no final.
FRONTEND_URL=http://seu-dominio-ou-ip

# -- Google Sign-In -------------------------------------------
# __ vira chave aninhada (Authentication:Google:...) no ASP.NET Core.
# O backend so valida o ID token - nao precisa mais de ClientSecret.
Authentication__Google__ClientId=seu_google_client_id

# -- Frontend (Vite) ------------------------------------------
# Embutido no bundle no momento do build (relativo, atras do nginx).
VITE_API_URL=/api
# Client ID do Google usado pelo GIS no navegador (mesmo valor do backend).
VITE_GOOGLE_CLIENT_ID=seu_google_client_id
